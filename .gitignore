# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Source packages (not part of the site)
*.zip

# Source research files (kept local; NOT served on the public site).
# Ignore every root-level .md (research/deep-search dumps) except the README.
/*.md
!/README.md

# Draft page uploads — integrated into the site at their canonical paths,
# not served raw from the repo root.
/preview-*.html
/index_[0-9]*.html

# Local helpers (not part of the site)
/normalize_nav.py
/.ghtoken
